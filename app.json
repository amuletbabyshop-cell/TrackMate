{
  "expo": {
    "name": "TrackMate",
    "slug": "trackmate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": { "resizeMode": "contain", "backgroundColor": "#0a0a0a" },
    "ios": { "supportsTablet": false, "bundleIdentifier": "com.trackmate.app" },
    "android": { "adaptiveIcon": { "backgroundColor": "#0a0a0a" }, "package": "com.trackmate.app" },
    "plugins": [
      "expo-router",
      ["expo-camera", { "cameraPermission": "フォーム分析のためカメラを使用します" }],
      ["expo-image-picker", { "photosPermission": "食事・動画を記録するために写真ライブラリを使用します" }]
    ],
    "scheme": "trackmate",
    "web": { "bundler": "metro" }
  }
}
